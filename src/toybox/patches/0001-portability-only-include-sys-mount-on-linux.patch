From 17c48f106d815b73e4461d0f39b67e896deee302 Mon Sep 17 00:00:00 2001
From: Kevin Alavik <kevin@alavik.se>
Date: Mon, 23 Mar 2026 00:00:00 +0000
Subject: [PATCH] portability: only include sys/mount.h on linux

Aurix does not provide Linux-specific headers like sys/mount.h.
Restrict that include to Linux targets so generic library code can build
with POSIX-only headers.
---
 lib/portability.h | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/lib/portability.h b/lib/portability.h
index b5e8f89..23f7a6b 100644
--- a/lib/portability.h
+++ b/lib/portability.h
@@ -168,8 +168,8 @@
 #endif
 
 // Linux headers not listed by POSIX or LSB
-#include <sys/mount.h>
 #ifdef __linux__
+#include <sys/mount.h>
 #include <sys/statfs.h>
 #include <sys/swap.h>
 #include <sys/sysinfo.h>
